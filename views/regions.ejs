<section class="guide-hero">
  <div class="container">
    <div class="hero-eyebrow">Nationwide Rollout</div>
    <h1 style="font-size:2.8rem;">Find Your Region</h1>
    <p class="sub" style="margin:1rem auto 0;">Gym League Global is expanding region by region across Australia. Search below to find your local competition, or apply to bring GLG to your area.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="grid grid-2">
      <% regions.forEach(r => { %>
        <div class="card region-card">
          <div>
            <div class="rname"><%= r.name %></div>
            <div style="font-size:.78rem;color:var(--muted);margin-top:.2rem;">New South Wales</div>
          </div>
          <% if (r.status === 'active') { %>
            <a href="/regions/<%= r.slug %>" class="badge badge-live">Live — View</a>
          <% } else { %>
            <span class="badge badge-soon">Coming Soon</span>
          <% } %>
        </div>
      <% }) %>
    </div>

    <div class="card" style="margin-top:2rem;background:var(--forest);color:#fff;text-align:center;padding:2.4rem;">
      <h3 style="font-size:1.6rem;color:#fff;">Don't see your area?</h3>
      <p style="color:#C7D0CB;margin:.6rem 0 1.2rem;">Apply to become a GLG League Franchise Operator and bring the competition to your region.</p>
      <a href="/signup/league" class="btn btn-primary">Apply to Run a Region</a>
    </div>
  </div>
</section>
