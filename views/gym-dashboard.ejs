<div class="dash-shell">
  <div class="dash-side">
    <a href="/gym" class="active">Dashboard</a>
    <a href="/gym/fixtures">Fixtures</a>
    <a href="/profile">My Account</a>
    <a href="/guide/gym">Gym Guide</a>
  </div>
  <div class="dash-main">
    <% if (welcome) { %><div class="form-success">Gym registered! Here's your dashboard.</div><% } %>
    <div class="section-eyebrow">Gym Dashboard</div>
    <h2><%= gym.name %></h2>
    <p style="color:var(--muted);margin-top:.3rem;">Manage your teams and roster.</p>

    <h3 style="margin-top:2rem;font-size:1.4rem;color:var(--forest);">Your Teams</h3>
    <div class="grid grid-3" style="margin-top:.8rem;">
      <% teams.forEach(t => { %>
        <a href="/gym/team/<%= t.id %>" class="card" style="display:block;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;color:var(--forest);"><%= t.name %></div>
          <div style="font-size:.82rem;color:var(--muted);margin-top:.3rem;"><%= rosterCounts[t.id] %> athletes · <%= t.division %></div>
        </a>
      <% }) %>
    </div>

    <div class="card" style="margin-top:1rem;">
      <form method="POST" action="/gym/teams/new" style="display:flex;gap:.8rem;align-items:flex-end;flex-wrap:wrap;">
        <div style="flex:1;min-width:200px;">
          <label style="margin-top:0;">New Team Name</label>
          <input type="text" name="name" placeholder="e.g. Pymble Ravens" required>
        </div>
        <div style="min-width:160px;">
          <label style="margin-top:0;">Division</label>
          <select name="division">
            <option value="Open">Open</option>
            <option value="Elite">Elite</option>
            <option value="Beginner">Beginner</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">+ Add Team</button>
      </form>
    </div>

    <h3 style="margin-top:2.5rem;font-size:1.4rem;color:var(--forest);">Unassigned Athlete Pool — Your Region</h3>
    <p class="lede">Athletes who signed up asking to be assigned. Pull them into one of your teams.</p>
    <div class="table-wrap">
      <table>
        <tr><th>Name</th><th>Gender</th><th>Email</th><th>Assign To</th></tr>
        <% if (pool.length === 0) { %>
          <tr><td colspan="4" style="color:var(--muted);text-align:center;padding:1.5rem;">No unassigned athletes right now.</td></tr>
        <% } %>
        <% pool.forEach(p => { %>
          <tr>
            <td><%= p.first_name %> <%= p.last_name %></td>
            <td><%= p.gender %></td>
            <td style="color:var(--muted);"><%= p.email %></td>
            <td>
              <form method="POST" action="/gym/pool/assign" style="display:flex;gap:.5rem;">
                <input type="hidden" name="athlete_id" value="<%= p.athlete_id %>">
                <select name="team_id" required>
                  <option value="">Choose team</option>
                  <% teams.forEach(t => { %><option value="<%= t.id %>"><%= t.name %></option><% }) %>
                </select>
                <button type="submit" class="btn btn-primary btn-sm">Assign</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </table>
    </div>
  </div>
</div>
