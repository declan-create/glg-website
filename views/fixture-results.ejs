<section class="section">
  <div class="container">
    <% if (query.saved) { %><div class="form-success">Results saved and scores recalculated.</div><% } %>
    <div class="section-eyebrow">Week <%= fixture.week %></div>
    <h2><%= fixture.team_a_name %> vs <%= fixture.team_b_name %></h2>
    <p class="lede">Enter each category's result — for Singles that's the one athlete's number; for Doubles/Mixed, enter the pair's single combined performance (total reps counted for the pair), exactly as called on the day. Points are calculated automatically: benchmark hit, and margin over the same category on the opposing team.</p>

    <form method="POST" action="/fixture/<%= fixture.id %>/results">
      <% const categories = ['mens_singles','womens_singles','mens_doubles','womens_doubles','mixed_doubles']; %>

      <% gates.forEach(gate => { %>
        <% const gateExercises = exercises.filter(e => e.gate_id === gate.id); %>
        <h3 style="margin-top:2.2rem;font-size:1.4rem;color:var(--forest);">Gate <%= gate.number %> — <%= gate.name %></h3>

        <% if (!gate.is_sprint_finish) { %>
          <% gateExercises.forEach(ex => { %>
            <div class="card" style="margin-top:.8rem;">
              <div style="font-family:'Barlow Condensed',sans-serif;font-weight:700;color:var(--forest);margin-bottom:.2rem;"><%= ex.name %></div>
              <div style="font-size:.78rem;color:var(--muted);margin-bottom:.8rem;">Benchmark: <%= ex.benchmark_desc %> · unit: <%= ex.unit %> · doubles/mixed benchmarks are the combined total of both individual benchmarks</div>

              <div class="table-wrap">
                <table>
                  <tr><th>Category</th><th><%= fixture.team_a_name %></th><th><%= fixture.team_b_name %></th></tr>
                  <% categories.forEach(cat => { %>
                    <tr>
                      <td>
                        <div style="font-weight:600;"><%= categoryLabel[cat] %></div>
                        <div style="font-size:.72rem;color:var(--muted);">
                          A: <%= (namesA[cat] || []).join(' & ') || '—' %><br>
                          B: <%= (namesB[cat] || []).join(' & ') || '—' %>
                        </div>
                      </td>
                      <td>
                        <% const rA = resultMap[fixture.team_a_id+'_'+ex.id+'_'+cat]; %>
                        <input type="number" step="0.1" style="width:110px;" name="result_<%= fixture.team_a_id %>_<%= ex.id %>_<%= cat %>"
                          value="<%= rA ? rA.raw_value : '' %>" placeholder="<%= ex.unit %>" <%= (namesA[cat]||[]).length ? '' : 'disabled' %>>
                        <% if (rA) { %><span class="pill" style="font-size:.6rem;"><%= rA.points %>pt</span><% } %>
                      </td>
                      <td>
                        <% const rB = resultMap[fixture.team_b_id+'_'+ex.id+'_'+cat]; %>
                        <input type="number" step="0.1" style="width:110px;" name="result_<%= fixture.team_b_id %>_<%= ex.id %>_<%= cat %>"
                          value="<%= rB ? rB.raw_value : '' %>" placeholder="<%= ex.unit %>" <%= (namesB[cat]||[]).length ? '' : 'disabled' %>>
                        <% if (rB) { %><span class="pill" style="font-size:.6rem;"><%= rB.points %>pt</span><% } %>
                      </td>
                    </tr>
                  <% }) %>
                </table>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="card" style="margin-top:.8rem;">
            <div style="font-size:.82rem;color:var(--muted);margin-bottom:1rem;">All 3 exercises combined as one timed sprint, per category. Completion = 3pts. Fastest category-vs-category = +3pts.</div>
            <div class="table-wrap">
              <table>
                <tr><th>Category</th><th><%= fixture.team_a_name %></th><th><%= fixture.team_b_name %></th></tr>
                <% categories.forEach(cat => { %>
                  <tr>
                    <td>
                      <div style="font-weight:600;"><%= categoryLabel[cat] %></div>
                      <div style="font-size:.72rem;color:var(--muted);">
                        A: <%= (namesA[cat] || []).join(' & ') || '—' %><br>
                        B: <%= (namesB[cat] || []).join(' & ') || '—' %>
                      </div>
                    </td>
                    <td>
                      <% const gA = g4Map[fixture.team_a_id+'_'+cat]; %>
                      <label style="display:flex;align-items:center;gap:.4rem;font-size:.72rem;text-transform:none;letter-spacing:0;font-weight:500;margin:0;">
                        <input type="checkbox" name="g4_<%= fixture.team_a_id %>_<%= cat %>_completed" <%= gA && gA.completed ? 'checked' : '' %> style="width:auto;" <%= (namesA[cat]||[]).length ? '' : 'disabled' %>> Completed
                      </label>
                      <input type="number" step="0.1" style="width:90px;margin-top:.3rem;" name="g4_<%= fixture.team_a_id %>_<%= cat %>_time" placeholder="sec"
                        value="<%= gA ? gA.total_time_sec : '' %>" <%= (namesA[cat]||[]).length ? '' : 'disabled' %>>
                      <% if (gA) { %><span class="pill" style="font-size:.6rem;"><%= gA.points %>pt</span><% } %>
                    </td>
                    <td>
                      <% const gB = g4Map[fixture.team_b_id+'_'+cat]; %>
                      <label style="display:flex;align-items:center;gap:.4rem;font-size:.72rem;text-transform:none;letter-spacing:0;font-weight:500;margin:0;">
                        <input type="checkbox" name="g4_<%= fixture.team_b_id %>_<%= cat %>_completed" <%= gB && gB.completed ? 'checked' : '' %> style="width:auto;" <%= (namesB[cat]||[]).length ? '' : 'disabled' %>> Completed
                      </label>
                      <input type="number" step="0.1" style="width:90px;margin-top:.3rem;" name="g4_<%= fixture.team_b_id %>_<%= cat %>_time" placeholder="sec"
                        value="<%= gB ? gB.total_time_sec : '' %>" <%= (namesB[cat]||[]).length ? '' : 'disabled' %>>
                      <% if (gB) { %><span class="pill" style="font-size:.6rem;"><%= gB.points %>pt</span><% } %>
                    </td>
                  </tr>
                <% }) %>
              </table>
            </div>
          </div>
        <% } %>
      <% }) %>

      <button type="submit" class="btn btn-primary" style="margin-top:2rem;">Save Results & Recalculate Scores</button>
    </form>

    <h3 style="margin-top:2.5rem;font-size:1.4rem;color:var(--forest);">Judge Assignments</h3>
    <p class="lede">Assign a judge to a gate so they can log in and enter scores for just that gate as each exercise finishes. The judge needs an account already — they can apply via the Participant sign-up or you can create one for them.</p>

    <div class="table-wrap" style="margin-bottom:1rem;">
      <table>
        <tr><th>Gate</th><th>Judge</th><th></th></tr>
        <% if (judgeAssignments.length === 0) { %>
          <tr><td colspan="3" style="color:var(--muted);text-align:center;padding:1rem;">No judges assigned yet.</td></tr>
        <% } %>
        <% judgeAssignments.forEach(ja => { %>
          <tr>
            <td>Gate <%= ja.gate_number %> — <%= ja.gate_name %></td>
            <td><%= ja.first_name %> <%= ja.last_name %> (<%= ja.judge_email %>)</td>
            <td>
              <form method="POST" action="/fixture/<%= fixture.id %>/unassign-judge/<%= ja.id %>">
                <button type="submit" class="btn btn-outline btn-sm" style="border-color:var(--danger);color:var(--danger);">Remove</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </table>
    </div>

    <div class="card">
      <form method="POST" action="/fixture/<%= fixture.id %>/assign-judge" style="display:flex;gap:.8rem;align-items:flex-end;flex-wrap:wrap;">
        <div style="flex:1;min-width:220px;">
          <label style="margin-top:0;">Judge's Email</label>
          <input type="email" name="judge_email" placeholder="judge@example.com" required>
        </div>
        <div style="min-width:200px;">
          <label style="margin-top:0;">Gate</label>
          <select name="gate_id" required>
            <% gates.forEach(g => { %><option value="<%= g.id %>">Gate <%= g.number %> — <%= g.name %></option><% }) %>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Assign Judge</button>
      </form>
    </div>
  </div>
</section>
