<div class="dash-shell">
  <div class="dash-side">
    <a href="/gym">Dashboard</a>
    <a href="/gym/fixtures">Fixtures</a>
    <a href="/account">My Account</a>
    <a href="/guide/gym">Gym Guide</a>
  </div>
  <div class="dash-main">
    <div class="section-eyebrow"><%= gym.name %></div>
    <h2><%= team.name %></h2>

    <% if (query.saved) { %><div class="form-success">Member details updated.</div><% } %>
    <% if (query.added) { %><div class="form-success">New member added to the team.</div><% } %>
    <% if (query.error === 'email') { %><div class="form-error">Please enter a valid email address.</div><% } %>
    <% if (query.error === 'emailtaken') { %><div class="form-error">That email is already in use by another account.</div><% } %>
    <% if (query.error === 'name') { %><div class="form-error">Please enter a valid first name.</div><% } %>
    <% if (query.error === 'gender') { %><div class="form-error">Please select a gender.</div><% } %>
    <% if (query.error === 'category') { %><div class="form-error">Please select a valid category.</div><% } %>
    <% if (newPassword) { %>
      <div class="form-success">
        New password set for this member: <strong style="font-family:'Roboto Mono',monospace;font-size:1rem;"><%= newPassword %></strong>
        — pass this along to them directly (there's no automatic email yet). They should change it themselves once logged in, from their own account page.
      </div>
    <% } %>

    <h3 style="margin-top:1.6rem;font-size:1.3rem;color:var(--forest);">Roster (<%= roster.length %>)</h3>
    <p class="lede">Most athletes will sign up themselves and you'll pick them up from the unassigned pool on your dashboard — but you can also add or edit a member directly here (handy before everyone's signed up, or to fix a typo). Every member needs a category assigned before results can be entered for them.</p>

    <% if (roster.length === 0) { %>
      <div class="card" style="text-align:center;color:var(--muted);padding:2rem;">No members on this team yet — add one below, or assign someone from your dashboard's unassigned pool.</div>
    <% } %>

    <% roster.forEach(r => { %>
      <div class="card" style="margin-top:.8rem;">
        <form method="POST" action="/gym/team/<%= team.id %>/update-member" style="display:grid;grid-template-columns:1fr 1fr 1.4fr 1fr .7fr 1.3fr auto;gap:.7rem;align-items:end;">
          <input type="hidden" name="athlete_id" value="<%= r.athlete_id %>">
          <div>
            <label style="margin-top:0;">First Name</label>
            <input type="text" name="first_name" value="<%= r.first_name %>" required>
          </div>
          <div>
            <label style="margin-top:0;">Last Name</label>
            <input type="text" name="last_name" value="<%= r.last_name %>">
          </div>
          <div>
            <label style="margin-top:0;">Email</label>
            <input type="email" name="email" value="<%= r.email %>" required>
          </div>
          <div>
            <label style="margin-top:0;">Phone</label>
            <input type="text" name="phone" value="<%= r.phone || '' %>">
          </div>
          <div>
            <label style="margin-top:0;">Gender</label>
            <select name="gender">
              <option value="M" <%= r.gender==='M'?'selected':'' %>>M</option>
              <option value="F" <%= r.gender==='F'?'selected':'' %>>F</option>
            </select>
          </div>
          <div>
            <label style="margin-top:0;">Category</label>
            <select name="category">
              <option value="" <%= !r.category ? 'selected' : '' %>>— Unassigned —</option>
              <option value="mens_singles" <%= r.category==='mens_singles'?'selected':'' %>>Men's Singles</option>
              <option value="womens_singles" <%= r.category==='womens_singles'?'selected':'' %>>Women's Singles</option>
              <option value="mens_doubles" <%= r.category==='mens_doubles'?'selected':'' %>>Men's Doubles</option>
              <option value="womens_doubles" <%= r.category==='womens_doubles'?'selected':'' %>>Women's Doubles</option>
              <option value="mixed_doubles" <%= r.category==='mixed_doubles'?'selected':'' %>>Mixed Doubles</option>
            </select>
          </div>
          <div style="display:flex;gap:.5rem;">
            <button type="submit" class="btn btn-primary btn-sm">Save</button>
          </div>
        </form>
        <div style="display:flex;gap:.6rem;margin-top:.6rem;">
          <form method="POST" action="/gym/team/<%= team.id %>/remove-athlete" onsubmit="return confirm('Remove this member from the team?')">
            <input type="hidden" name="athlete_id" value="<%= r.athlete_id %>">
            <button type="submit" class="btn btn-outline btn-sm" style="border-color:var(--danger);color:var(--danger);">Remove from Team</button>
          </form>
          <form method="POST" action="/gym/team/<%= team.id %>/reset-password" onsubmit="return confirm('Reset this member\'s password? Their old password will stop working.')">
            <input type="hidden" name="athlete_id" value="<%= r.athlete_id %>">
            <button type="submit" class="btn btn-outline btn-sm" style="border-color:var(--forest);color:var(--forest);">Reset Password</button>
          </form>
        </div>
      </div>
    <% }) %>

    <h3 style="margin-top:2.2rem;font-size:1.3rem;color:var(--forest);">Add a New Member</h3>
    <p class="lede">For anyone who hasn't signed up themselves yet. They'll be able to log in with the email below and the default password <strong>GLGWelcome2026!</strong> — worth passing that along to them directly since there's no automatic email sent yet.</p>
    <div class="card">
      <form method="POST" action="/gym/team/<%= team.id %>/add-member" style="display:grid;grid-template-columns:1fr 1fr 1.4fr 1fr .7fr 1.3fr auto;gap:.7rem;align-items:end;">
        <div>
          <label style="margin-top:0;">First Name</label>
          <input type="text" name="first_name" required>
        </div>
        <div>
          <label style="margin-top:0;">Last Name</label>
          <input type="text" name="last_name">
        </div>
        <div>
          <label style="margin-top:0;">Email</label>
          <input type="email" name="email" required>
        </div>
        <div>
          <label style="margin-top:0;">Phone</label>
          <input type="text" name="phone">
        </div>
        <div>
          <label style="margin-top:0;">Gender</label>
          <select name="gender" required>
            <option value="">—</option>
            <option value="M">M</option>
            <option value="F">F</option>
          </select>
        </div>
        <div>
          <label style="margin-top:0;">Category</label>
          <select name="category">
            <option value="">— Unassigned —</option>
            <option value="mens_singles">Men's Singles</option>
            <option value="womens_singles">Women's Singles</option>
            <option value="mens_doubles">Men's Doubles</option>
            <option value="womens_doubles">Women's Doubles</option>
            <option value="mixed_doubles">Mixed Doubles</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Add Member</button>
      </form>
    </div>

    <a href="/gym" style="display:inline-block;margin-top:1.5rem;color:var(--forest);font-weight:700;font-family:'Barlow Condensed',sans-serif;">← Back to Dashboard</a>
  </div>
</div>
