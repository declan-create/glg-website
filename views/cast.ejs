<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>GLG Live — <%= fixture.team_a_name %> vs <%= fixture.team_b_name %></title>
<link rel="stylesheet" href="/css/style.css">
<style>
  .board-body{background:var(--forest);color:var(--white);margin:0;min-height:100vh;font-family:'DM Sans',sans-serif;}
  .board-wrap{max-width:1500px;margin:0 auto;padding:2vh 2vw 4vh;}
  .board-top{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem;}
  .board-fixture{font-family:'Bebas Neue',sans-serif;font-size:2.4rem;color:var(--lime);line-height:1;}
  .board-sub{font-family:'Barlow Condensed',sans-serif;font-weight:700;letter-spacing:.1em;color:#8AA398;font-size:.9rem;margin-top:.3rem;}
  .fullscreen-btn{background:rgba(241,245,249,.1);color:var(--white);border:1px solid rgba(241,245,249,.2);
    padding:.55rem 1rem;border-radius:8px;font-family:'Barlow Condensed',sans-serif;font-weight:700;
    font-size:.8rem;cursor:pointer;letter-spacing:.05em;text-transform:uppercase;}
  .fullscreen-btn:hover{background:var(--lime);color:var(--forest);border-color:var(--lime);}

  .gate-tabs{display:flex;gap:.6rem;margin-top:1.2rem;flex-wrap:wrap;}
  .gate-tab{background:rgba(241,245,249,.08);border:1px solid rgba(241,245,249,.15);color:var(--white);
    font-family:'Barlow Condensed',sans-serif;font-weight:800;letter-spacing:.06em;font-size:.85rem;
    padding:.6rem 1.2rem;border-radius:8px;cursor:pointer;text-transform:uppercase;}
  .gate-tab.active{background:var(--lime);color:var(--forest);border-color:var(--lime);}

  .clock-row{display:flex;align-items:center;justify-content:center;gap:2rem;margin:2rem 0 1.5rem;}
  .master-clock{font-family:'Roboto Mono',monospace;font-weight:700;font-size:clamp(2.2rem, 9vw, 5rem);letter-spacing:.02em;}
  .master-clock.finished{color:var(--lime);}
  .clock-label{font-family:'Barlow Condensed',sans-serif;font-weight:700;letter-spacing:.14em;color:#8AA398;font-size:.85rem;text-align:center;margin-bottom:.3rem;}
  .clock-controls{display:flex;gap:.6rem;}
  .clock-controls button{background:rgba(241,245,249,.1);color:var(--white);border:1px solid rgba(241,245,249,.2);
    padding:.7rem 1.4rem;border-radius:8px;font-family:'Barlow Condensed',sans-serif;font-weight:700;
    font-size:.9rem;cursor:pointer;letter-spacing:.05em;text-transform:uppercase;}
  .clock-controls button:hover{background:var(--lime);color:var(--forest);border-color:var(--lime);}
  .clock-controls button.danger:hover{background:#DC2626;color:#fff;border-color:#DC2626;}

  .cat-grid{display:grid;grid-template-columns:1fr;gap:.7rem;margin-top:1rem;}
  .cat-row{display:grid;grid-template-columns:1.3fr 1.6fr 1.6fr 1fr;gap:1rem;align-items:center;
    background:rgba(241,245,249,.05);border:1px solid rgba(241,245,249,.1);border-radius:10px;padding:1rem 1.4rem;}
  .cat-row.is-live{border-color:var(--lime);background:rgba(163,230,53,.08);}
  .cat-row.is-done{opacity:.45;}
  .cat-name{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;color:var(--lime);}
  .cat-athletes{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:.85rem;line-height:1.5;}
  .cat-athletes .side{display:block;}
  .cat-athletes .team-tag{color:#8AA398;font-weight:700;margin-right:.4rem;}
  .cat-stage{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;}
  .cat-stage .stagelabel{display:block;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.65rem;letter-spacing:.12em;color:#8AA398;text-transform:uppercase;margin-bottom:.15rem;}
  .cat-remaining{font-family:'Roboto Mono',monospace;font-weight:700;font-size:1.6rem;text-align:right;}

  .legend{display:flex;gap:1.5rem;justify-content:center;margin-top:1.5rem;font-size:.78rem;color:#8AA398;font-family:'Barlow Condensed',sans-serif;font-weight:600;letter-spacing:.04em;}
  .legend span::before{content:"● ";}
  .legend .l-live::before{color:var(--lime);}
  .legend .l-wait::before{color:#8AA398;}
  .legend .l-done::before{color:#4E655B;}
</style>
</head>
<body class="board-body">

<div class="board-wrap">
  <div class="board-top">
    <div>
      <div class="board-fixture"><%= fixture.team_a_name %> <span style="color:#4E655B;">vs</span> <%= fixture.team_b_name %></div>
      <div class="board-sub">WEEK <%= fixture.week %> · LIVE MATCH BOARD (CONTROLLER)</div>
    </div>
    <button class="fullscreen-btn" onclick="toggleFullscreen()">⛶ Fullscreen</button>
  </div>

  <div class="clock-row">
    <div>
      <div class="clock-label">FULL EVENT — GATES 1–4</div>
      <div class="master-clock" id="masterClock">00:00</div>
    </div>
    <div class="clock-controls">
      <button onclick="startClock()">Start</button>
      <button onclick="pauseClock()">Pause</button>
      <button class="danger" onclick="resetClock()">Reset</button>
    </div>
  </div>

  <div class="cat-grid" id="catGrid"></div>

  <div class="legend">
    <span class="l-live">Currently competing</span>
    <span class="l-wait">Not started yet</span>
    <span class="l-done">Finished</span>
  </div>
</div>

<script>
  const FIXTURE_ID = <%= fixture.id %>;
  const gates = <%- JSON.stringify(gates) %>;
  const exercises = <%- JSON.stringify(exercises) %>;
  const groupedA = <%- JSON.stringify(groupedA) %>;
  const groupedB = <%- JSON.stringify(groupedB) %>;
  const categoryLabel = <%- JSON.stringify(categoryLabel) %>;
  const fixture = { team_a_name: <%- JSON.stringify(fixture.team_a_name) %>, team_b_name: <%- JSON.stringify(fixture.team_b_name) %> };

  const categoryOrder = ['mens_singles','womens_singles','mens_doubles','womens_doubles','mixed_doubles'];
  const OFFSET_SEC = 5 * 60;
  const STAGE_SEC = 5 * 60;
  const CLOCK_MODE = 'full_event'; // one continuous clock for the whole fixture

  const gates123 = gates.filter(g => !g.is_sprint_finish).sort((a,b) => a.number - b.number);
  const gate4 = gates.find(g => g.is_sprint_finish);
  const gate4Exercises = gate4 ? exercises.filter(e => e.gate_id === gate4.id) : [];

  // One continuous list: the 9 timed exercises from Gates 1-3. Gate 4 is not
  // in this list — it has no time limit (see GATE4_NAME / GATES123_SEC below).
  // No manual switching between gates; everything flows off one clock.
  const STAGES = [
    ...gates123.flatMap(g => exercises.filter(e => e.gate_id === g.id).map(e => ({ name: `Gate ${g.number}: ${e.name}`, seconds: STAGE_SEC }))),
  ];
  // Gate 4 is OPEN-ENDED: it takes as long as it takes. Once a category has
  // finished the 9 timed stages of Gates 1-3, its clock flips to a stopwatch
  // counting UP until the operator pauses/resets — no fixed 15-minute block.
  const GATES123_SEC = STAGES.reduce((s,x) => s+x.seconds, 0);
  const GATE4_NAME = `Gate 4: Sprint Finish (${gate4Exercises.map(e=>e.name).join(' → ')})`;

  let serverElapsed = 0, serverRunning = false, lastPollTime = Date.now();

  function fmt(sec, showMs){
    sec = Math.max(0, sec);
    const whole = Math.floor(sec);
    const m = String(Math.floor(whole/60)).padStart(2,'0');
    const s = String(whole%60).padStart(2,'0');
    if (!showMs) return m+':'+s;
    const ms = String(Math.floor((sec - whole) * 1000)).padStart(3,'0');
    return m+':'+s+'.'+ms;
  }

  async function pollClock(){
    try {
      const res = await fetch(`/api/fixture/${FIXTURE_ID}/clock/${CLOCK_MODE}`);
      const data = await res.json();
      serverElapsed = data.elapsedSeconds;
      serverRunning = data.running;
      lastPollTime = Date.now();
    } catch (e) { /* keep last known state on a transient network hiccup */ }
  }
  async function startClock(){ await fetch(`/api/fixture/${FIXTURE_ID}/clock/${CLOCK_MODE}/start`, { method: 'POST' }); pollClock(); }
  async function pauseClock(){ await fetch(`/api/fixture/${FIXTURE_ID}/clock/${CLOCK_MODE}/pause`, { method: 'POST' }); pollClock(); }
  async function resetClock(){ await fetch(`/api/fixture/${FIXTURE_ID}/clock/${CLOCK_MODE}/reset`, { method: 'POST' }); pollClock(); }

  function currentDisplaySeconds(){
    if (!serverRunning) return serverElapsed;
    return serverElapsed + (Date.now() - lastPollTime) / 1000;
  }

  function renderBoard(){
    const masterSeconds = currentDisplaySeconds();

    const clockEl = document.getElementById('masterClock');
    clockEl.textContent = fmt(masterSeconds, true);

    document.getElementById('catGrid').innerHTML = categoryOrder.map((cat, i) => {
      const offset = i * OFFSET_SEC;
      const elapsed = masterSeconds - offset;
      const namesA = (groupedA[cat] || []).join(' & ') || '—';
      const namesB = (groupedB[cat] || []).join(' & ') || '—';
      const athletesHtml = `<span class="side"><span class="team-tag">${fixture.team_a_name}:</span>${namesA}</span><span class="side"><span class="team-tag">${fixture.team_b_name}:</span>${namesB}</span>`;

      let rowClass = '', stageLabel = '', stageName = '', remaining = '';
      if (elapsed < 0) { rowClass='is-wait'; stageLabel='Starts in'; stageName=fmt(-elapsed); }
      else if (elapsed >= GATES123_SEC) {
        rowClass='is-live';
        stageLabel = 'Sprint time (counting up)';
        stageName = GATE4_NAME;
        remaining = fmt(elapsed - GATES123_SEC, true);
      }
      else {
        rowClass='is-live';
        let cum=0, stageIdx=0;
        for (let s=0;s<STAGES.length;s++){ if (elapsed<cum+STAGES[s].seconds){stageIdx=s;break;} cum+=STAGES[s].seconds; }
        stageLabel = `Stage ${stageIdx+1} of ${STAGES.length+1}`;
        stageName = STAGES[stageIdx].name;
        remaining = fmt(STAGES[stageIdx].seconds - (elapsed-cum), true);
      }
      return `<div class="cat-row ${rowClass}">
          <div class="cat-name">${categoryLabel[cat]}</div>
          <div class="cat-athletes">${athletesHtml}</div>
          <div class="cat-stage"><span class="stagelabel">${stageLabel}</span>${stageName}</div>
          <div class="cat-remaining">${remaining}</div>
        </div>`;
    }).join('');
  }

  function toggleFullscreen(){
    if (!document.fullscreenElement) document.documentElement.requestFullscreen().catch(()=>{});
    else document.exitFullscreen();
  }

  pollClock().then(renderBoard);
  setInterval(renderBoard, 33);   // ~30fps, smooth enough for the millisecond display
  setInterval(pollClock, 1000);    // stay in sync with the server / other viewers

  document.addEventListener('keydown', (e) => {
    if (e.code === 'Space') { e.preventDefault(); serverRunning ? pauseClock() : startClock(); }
    if (e.code === 'KeyR') resetClock();
  });
</script>

</body>
</html>
