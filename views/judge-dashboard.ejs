<section class="section">
  <div class="container">
    <div class="section-eyebrow">Judge</div>
    <h2>Your Assignments</h2>
    <p class="lede">These are the participant groups you've been assigned to judge. You follow your group through every exercise — click one to enter scores as each exercise finishes.</p>

    <div class="table-wrap">
      <table>
        <tr><th>Fixture</th><th>Week</th><th>Category</th><th></th></tr>
        <% if (assignments.length === 0) { %>
          <tr><td colspan="4" style="color:var(--muted);text-align:center;padding:1.5rem;">You haven't been assigned to any categories yet — check with the gym running your event.</td></tr>
        <% } %>
        <% assignments.forEach(a => { %>
          <tr>
            <td><%= a.team_a_name %> vs <%= a.team_b_name %></td>
            <td>Week <%= a.week %></td>
            <td><%= categoryLabel[a.category] || a.category %></td>
            <td>
              <a href="/judge/fixture/<%= a.fixture_id %>/category/<%= a.category %>/live" class="btn btn-primary btn-sm">Live Counter</a>
              <a href="/judge/fixture/<%= a.fixture_id %>/category/<%= a.category %>" class="btn btn-outline btn-sm">All Results</a>
            </td>
          </tr>
        <% }) %>
      </table>
    </div>
    <a href="/account" style="display:inline-block;margin-top:1.5rem;color:var(--forest);font-weight:700;font-family:'Barlow Condensed',sans-serif;">My Account</a>
  </div>
</section>
